APP_NAME=DailyPlan API
APP_ENV=development
APP_DEBUG=true
BACKEND_CORS_ORIGINS=["http://localhost:3000"]

DB_HOST=localhost
DB_PORT=5432
DB_USER=dailyplan
DB_PASSWORD=dailyplan
DB_NAME=dailyplan
DB_ECHO=false

JWT_SECRET_KEY=please-change-me-in-production
